# --- Server ---
# Railway provides PORT automatically; BACKEND_PORT is a local override.
BACKEND_PORT=3000
NODE_ENV=development

# --- Database ---
# Local SQLite (default). On Railway set this to the volume mount, e.g.
#   DATABASE_URL=file:/data/dev.db
# Or migrate to Postgres:
#   DATABASE_URL=postgresql://user:pass@host:5432/db
DATABASE_URL=file:./backend/prisma/dev.db

# --- Telegram bot (only required if you also deploy the bot) ---
BOT_TOKEN=
CHANNEL=
YOUTUBE=
CHANNEL_LINK=

# --- CORS ---
# Comma-separated list of origins allowed to call this API.
#   - CORS_ORIGINS="https://admin.vercel.app,https://www.example.com"
# If unset, FRONTEND_URL is used as a single origin. If both are unset,
# the server falls back to localhost dev origins.
#
# Set this to your Vercel production URL (and preview URLs if you want
# PR previews to work), e.g.
#   FRONTEND_URL=https://your-dashboard.vercel.app
FRONTEND_URL=
CORS_ORIGINS=
