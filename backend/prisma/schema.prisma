generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A source Telegram channel that holds the actual file messages.
/// Projects reference a Channel by id and pick a specific messageId
/// inside that channel. The bot reads the message directly with
/// `copyMessage`, so projects never need a `telegramFileId`.
model Channel {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  channelId String   @unique
  username  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
}

/// A "deep link" deliverable. Projects are reached via
/// https://t.me/<bot>?start=project_<slug>. The bot looks up the
/// project, runs verification, then `copyMessage`s the file from the
/// configured Channel + messageId.
///
/// Legacy `telegramFileId` is preserved for backward compatibility.
/// New projects should always set `channelId` + `messageId`.
model Project {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  description String?

  // New delivery model: copy a specific message from a channel.
  channelId Int?
  messageId Int?

  // Legacy delivery model (kept for backward compatibility only).
  telegramFileId String?
  telegramMessageLink String?

  thumbnail String?
  isActive  Boolean  @default(true)
  viewCount Int      @default(0)
  downloadCount Int      @default(0)
  failedVerificationCount Int @default(0)
  lastViewedAt DateTime?
  lastDownloadedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  pendingUsers User[]

  @@index([channelId, messageId])
}

model Platform {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  resources Resource[]
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  resources Resource[]
}

model Resource {
  id Int @id @default(autoincrement())

  name String
  slug String?

  description String?
  version     String?

  platformId Int
  categoryId Int

  downloadLink String?
  fixLink      String?

  tutorialChannelId String?
  tutorialMessageId Int?

  displayOrder Int     @default(0)
  isVisible    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platform Platform @relation(fields: [platformId], references: [id], onDelete: Restrict)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([slug])
  @@index([platformId])
  @@index([categoryId])
  @@index([displayOrder])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  pendingProjectId Int?
  pendingProject   Project? @relation(fields: [pendingProjectId], references: [id])
}
