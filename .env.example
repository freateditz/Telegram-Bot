# --- Bot (Telegram) ---
BOT_TOKEN=

# --- Channel / YouTube fallbacks (used by backend if Setting rows
# are missing; canonical values live in the Setting table) ---
CHANNEL=
YOUTUBE=
CHANNEL_LINK=

# --- Database ---
DATABASE_URL=file:./backend/prisma/dev.db

# --- Backend server ---
BACKEND_PORT=3000
NODE_ENV=development

# --- CORS ---
# Comma-separated origins allowed to call the backend. Set this on
# Railway to the Vercel deployment URL, e.g.
#   CORS_ORIGINS="https://your-dashboard.vercel.app"
# Or, for a single origin:
#   FRONTEND_URL=https://your-dashboard.vercel.app
CORS_ORIGINS=
FRONTEND_URL=
