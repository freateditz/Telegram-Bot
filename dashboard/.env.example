# =============================================================================
#  Local development env (loaded by `vite dev` and `vite build`).
# =============================================================================
#
#  VITE_API_BASE_URL must always end with `/api` because the frontend
#  composes paths like `${VITE_API_BASE_URL}/resources`.
#
#  For local dev:                  /api
#  For production: see .env.production
#
#  Vercel: in the project's Environment Variables, set VITE_API_BASE_URL
#  for Production + Preview environments. Values in Vercel OVERRIDE the
#  values in `.env.production`.
# =============================================================================

VITE_API_BASE_URL=/api

VITE_APP_NAME=Admin Dashboard

# Telegram bot username (without the @) used to build project deep
# links shown in the dashboard. Defaults to FreatEditzResources_Bot
# when unset.
VITE_BOT_USERNAME=FreatEditzResources_Bot
