# API base URL — must always end with `/api` because the frontend
# composes paths like `${VITE_API_BASE_URL}/resources`.
#
#   Local dev (Vite proxy):       /api
#   Production (absolute URL):    https://<your-railway-app>.up.railway.app/api
#
# For Vercel: set VITE_API_BASE_URL in the project's Environment
# Variables (Settings → Environment Variables). The value below is
# only used by `vite dev` locally.
VITE_API_BASE_URL=/api

# App metadata
VITE_APP_NAME=Admin Dashboard
